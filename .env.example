DATABASE_URL="postgresql://dmaga:dmaga@postgres:5432/dmaga"
REDIS_URL="redis://redis:6379"
FLARESOLVERR_URL="http://flaresolverr:8191/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional. Leave blank to use Real-Debrid's open-source client ID and device credentials flow.
REAL_DEBRID_CLIENT_ID=""
REAL_DEBRID_CLIENT_SECRET=""
TOKEN_ENCRYPTION_KEY=""
HOST_DOWNLOAD_DIR="/downloads"
# Non-debrid torrent download path (qBittorrent, rides the gluetun VPN netns).
QBITTORRENT_URL="http://gluetun:8080"
QBITTORRENT_USERNAME="admin"
# Set this to a known value. The linuxserver qBittorrent image logs a temporary
# random admin password on FIRST boot (`docker logs dmaga-qbittorrent`); log in
# with it once via http://<host>:8080, set this password under Settings → WebUI,
# then put it here and recreate the app/poller so they can authenticate.
QBITTORRENT_PASSWORD=""
TORRENT_DOWNLOAD_DIR="/downloads"
# Host directory backing the /downloads mount. Must live on the external T7 SSD
# (kept off the small SD card) and exist before `compose up`:
#   mkdir -p /media/pancho/T7/dmaga/downloads
DOWNLOADS_HOST_DIR="/media/pancho/T7/dmaga/downloads"
# NordVPN via gluetun (WireGuard/NordLynx). This is the WireGuard private key,
# NOT your account password or an access token. Get it from the NordVPN
# dashboard → Manual setup / NordLynx configuration (or generate it from your
# access token per gluetun's NordVPN wiki). Required to start the VPN stack.
NORDVPN_WIREGUARD_PRIVATE_KEY=""
# Optional VPN target country. gluetun uses full names with spaces, e.g.
# "Germany", "Netherlands", "United Kingdom". Germany/Netherlands tend to work
# best for public indexer access.
NORDVPN_COUNTRY="Germany"
# Build with the classic builder instead of Compose Bake. Bake without BuildKit
# enabled hangs `pnpm install` during the image build under podman.
COMPOSE_BAKE=false
